APP_ENV=development
APP_NAME=smartguard-backend
APP_VERSION=0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

DATABASE_URL=jdbc:postgresql://localhost:5434/smartguard
DATABASE_USERNAME=smartguard
DATABASE_PASSWORD=change_me_local_database_password
FLYWAY_ENABLED=true
FLYWAY_BASELINE_ON_MIGRATE=true
JPA_DDL_AUTO=update

DOPPLER_CONFIG=dev
DOPPLER_ENVIRONMENT=dev
DOPPLER_PROJECT=smartguard-backend

EXPO_PUSH_ACCESS_TOKEN=
EXPO_PUSH_ENABLED=false

JWT_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_DAYS=7
JWT_SECRET=change_me_minimum_32_characters_for_local_dev

LOG_LEVEL_APP=DEBUG
LOG_LEVEL_ROOT=INFO

MQTT_ENABLED=true
MQTT_BROKER_URL=tcp://localhost:1883
MQTT_CLIENT_ID=smartguard-backend
MQTT_PASSWORD=smartguard_mqtt_dev_password
MQTT_TOPIC_PREFIX=smartguard
MQTT_USERNAME=smartguard

SENSOR_SILENCE_MONITOR_ENABLED=true
SENSOR_SILENCE_MONITOR_FIXED_DELAY_MS=60000

POSTGRES_DB=smartguard
POSTGRES_PASSWORD=change_me_local_database_password
POSTGRES_USER=smartguard

SERVER_PORT=8080

WEBSOCKET_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006
WEBSOCKET_APP_PREFIX=/app
WEBSOCKET_ENDPOINT=/ws
WEBSOCKET_TOPIC_PREFIX=/topic
