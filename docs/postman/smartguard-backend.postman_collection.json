            "url": "{{baseUrl}}/api/v1/sensor-alert-rules/{{sensorAlertRuleId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"operator\": \"GREATER_THAN_OR_EQUAL\",\n  \"thresholdValue\": 700,\n  \"expectedBooleanValue\": null,\n  \"durationMinutes\": null,\n  \"alertType\": \"GAS_DETECTED\",\n  \"severity\": \"CRITICAL\",\n  \"message\": \"Gas level is at or above 700 ppm\",\n  \"enabled\": true\n}"
            }
          }
        },
        {
          "name": "Disable Sensor Alert Rule",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/v1/sensor-alert-rules/{{sensorAlertRuleId}}/disable"
          }
        }
