    {
      "name": "Devices",
      "item": [
        {
          "name": "Create Device",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('deviceId', json.device.id);",
                  "  pm.collectionVariables.set('deviceCode', json.device.code);",
                  "  pm.collectionVariables.set('deviceApiKey', json.apiKey);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/v1/devices",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"code\": \"{{deviceCode}}\",\n  \"name\": \"ESP32 Main Door\",\n  \"location\": \"Main entrance\",\n  \"ipAddress\": \"192.168.1.50\",\n  \"firmwareVersion\": \"1.0.0\"\n}"
            }
          }
        },
