          "name": "List Sensor Readings Filtered",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/sensors/{{sensorId}}/readings?from=2026-06-04T00:00:00Z&to=2026-06-04T23:59:59Z&limit=50"
          }
        },
        {
          "name": "Get Latest Sensor Reading",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/v1/sensors/{{sensorId}}/readings/latest"
          }
        },
        {
          "name": "Create Gas Threshold Rule",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('sensorAlertRuleId', json.id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/v1/sensors/{{sensorId}}/alert-rules",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"NUMERIC_THRESHOLD\",\n  \"operator\": \"GREATER_THAN\",\n  \"thresholdValue\": 700,\n  \"expectedBooleanValue\": null,\n  \"durationMinutes\": null,\n  \"alertType\": \"GAS_DETECTED\",\n  \"severity\": \"CRITICAL\",\n  \"message\": \"Gas level exceeded 700 ppm\"\n}"
            }
          }
        },
        {
          "name": "Create No Reading Rule",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/v1/sensors/{{sensorId}}/alert-rules",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"NO_READING\",\n  \"operator\": null,\n  \"thresholdValue\": null,\n  \"expectedBooleanValue\": null,\n  \"durationMinutes\": 5,\n  \"alertType\": \"DEVICE_OFFLINE\",\n  \"severity\": \"WARNING\",\n  \"message\": \"Sensor stopped reporting for 5 minutes\"\n}"
            }
          }
        },
