    {
      "key": "refreshToken",
      "value": ""
    },
    {
      "key": "userId",
      "value": ""
    },
    {
      "key": "deviceId",
      "value": ""
    },
    {
      "key": "deviceCode",
      "value": "esp32-001"
    },
    {
      "key": "deviceApiKey",
      "value": ""
    },
    {
      "key": "sensorId",
      "value": ""
    },
    {
      "key": "sensorCode",
      "value": "gas-main"
    },
    {
      "key": "sensorAlertRuleId",
      "value": ""
    },
    {
      "key": "readerId",
      "value": ""
    },
    {
      "key": "readerCode",
      "value": "rfid-main"
